        "message": "=Company: {{ $json.company_name }}\nWebsite: {{ $json.website }}\nLinkedIn: {{ $json.linkedin_url }}\nIndustry: {{ $json.industry }}\n\nSUBJECT:\n{{ $json.subject }}\n\nEMAIL BODY:\n{{ $json.body }}",
