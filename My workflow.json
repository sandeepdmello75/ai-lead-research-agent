    {
      "parameters": {
        "jsCode": "// Get LinkedIn data from Apify\nconst data = $input.item.json;\n\n// Extract clean fields\nconst company_name = data.name || 'Unknown Company';\nconst website = data.website || '';\nconst description = (data.description || '').slice(0, 500);\nconst industry = data.industries?.[0]?.title || 'Technology';\nconst employee_min = data.employeeCountRange?.start || '';\nconst employee_max = data.employeeCountRange?.end || '';\nconst employee_count = employee_min && employee_max\n  ? `${employee_min}-${employee_max}`\n  : 'Unknown';\nconst linkedin_url = data.linkedinUrl || '';\nconst location = data.locations?.[0]?.parsed?.text || '';\n\nreturn [{\n  json: {\n    company_name,\n    website,\n    description,\n    industry,\n    employee_count,\n    linkedin_url,\n    location\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [832, 48],
      "id": "node-6",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_GROQ_API_KEY_HERE"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={   \"model\": \"llama-3.3-70b-versatile\",   \"messages\": [     {       \"role\": \"user\",       \"content\": \"Write a cold email from Sandeep to the hiring manager of {{ $json.company_name }}. Industry: {{ $json.industry }}. Employees: {{ $json.employee_count }}. Description: {{ $json.description }}. Ask for a 15 minute call. Return only JSON: {\\\"subject\\\": \\\"here\\\", \\\"body\\\": \\\"here\\\"}\"     }   ],   \"max_tokens\": 400 }",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [1040, 48],
      "id": "node-7",
      "name": "HTTP Request1"
    },
    {
      "parameters": {
        "jsCode": "// Get Groq response\nconst data = $input.item.json;\n\n// Get email text\nconst rawText = data.choices[0].message.content;\n\n// Clean markdown\nconst cleaned = rawText\n  .replace(/```json\\n?/g, '')\n  .replace(/```\\n?/g, '')\n  .trim();\n\n// Parse email JSON\nlet emailData;\ntry {\n  emailData = JSON.parse(cleaned);\n} catch(e) {\n  emailData = {\n    subject: 'AI Engineering Opportunity',\n    body: cleaned\n  };\n}\n\n// Get company data from previous Code node\nconst prev = $('Code in JavaScript').first();\n\nreturn [{\n  json: {\n    subject: emailData.subject || 'AI Engineering Opportunity',\n    body: emailData.body || cleaned,\n    company_name: prev.json.company_name || '',\n    website: prev.json.website || '',\n    linkedin_url: prev.json.linkedin_url || '',\n    industry: prev.json.industry || ''\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1248, 48],
      "id": "node-8",
      "name": "Code in JavaScript1"
    },
